{
  "name": "adsense-sites-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node tools/build.mjs",
    "build:seasonal": "node tools/build-seasonal.mjs",
    "build:all": "node tools/build.mjs && node tools/build-seasonal.mjs && node tools/sync-docs.mjs",
